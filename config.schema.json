{
  "pluginAlias": "HomebridgeEasyMQTT",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "strictValidation": true,
  "schema": {
    "type": "object",
    "definitions": {
      "info": {
        "type": "object",
        "properties": {
          "name": {
              "type": "string",
              "title": "${config.title.name}",
              "required": true
          },
          "type": {
            "type": "string",
            "title": "${config.title.type}",
            "enum": [
              "LockMechanism",
              "Switch"
            ],
            "required": true
          },
          "manufacturer": {
            "type": "string",
            "title": "${config.title.manufacturer}"
          },
          "model": {
            "type": "string",
            "title": "${config.title.model}"
          },
          "serialNumber": {
            "type": "string",
            "title": "${config.title.serialNumber}"
          },
          "version": {
            "type": "string",
            "title": "${config.title.version}"
          }
        }
      },
      "mqtt": {
        "type": "object",
        "properties": {
          "broker": {
            "type": "string",
            "title": "${config.title.broker}",
            "placeholder": "mqtts://192.168.0.1:1883",
            "required": true
          },
          "options": {
            "type": "string",
            "title": "${config.title.options}",
            "description": "${config.description.options}",
            "placeholder": " { \"username\": \"fake@email.com\", \"password\": \"password123\" , \"rejectUnauthorized\": true }"
          }
        }
      }
    },    
    "properties": {
      "name": {
        "type": "string",
        "default": "Easy MQTT"
      },
      "accessories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "info": { "$ref": "#/definitions/info" },
            "mqtt": { "$ref": "#/definitions/mqtt" },
            "topicGetActive": {
              "type": "string",
              "title": "${config.title.topicGetActive}",
              "placeholder": "zwave/door_lock/front_door/status"
            },
            "topicGetCurrent": {
              "type": "string",
              "title": "${config.title.topicGetCurrent}",
              "placeholder": "zwave/door_lock/front_door/currentMode"
            },
            "topicGetTarget": {
              "type": "string",
              "title": "${config.title.topicGetTarget}",
              "placeholder": "zwave/door_lock/front_door/targetMode"
            },
            "topicSetTarget": {
              "type": "string",
              "title": "${config.title.topicSetTarget}",
              "placeholder": "zwave/door_lock/front_door/targetMode/set"
            },
            "topicGetOn": {
              "type": "string",
              "title": "${config.title.topicGetOn}",
              "placeholder": "home/living_room/lamp/state"
            },
            "topicSetOn": {
              "type": "string",
              "title": "${config.title.topicSetOn}",
              "placeholder": "home/living_room/lamp/state/set"
            },
            "valueActive": {
              "type": "string",
              "title": "${config.title.valueActive}",
              "description": "${config.description.valueActive}"
            },
            "valueSecured": {
              "type": "string",
              "title": "${config.title.valueSecured}"
            },
            "valueUnsecured": {
              "type": "string",
              "title": "${config.title.valueUnsecured}"
            },
            "valueJammed": {
              "type": "string",
              "title": "${config.title.valueJammed}"
            },
            "valueOn": {
              "type": "string",
              "title": "${config.title.valueOn}"
            },
            "valueOff": {
              "type": "string",
              "title": "${config.title.valueOff}"
            },
            "disableLogging": {
              "type": "boolean",
              "title": "${config.title.disableLogging}",
              "description": "${config.description.disableLogging}"
            }
          }
        },
        "default": []
      },
      "verbose": {
        "type": "boolean",
        "title": "${config.title.verbose}",
        "description": "${config.description.verbose}"
      }
    }
  },
  "layout": [
    {
      "type": "array",
      "key": "accessories",
      "title": "${config.title.accessories}",
      "items": [
        {
          "type": "fieldset",
          "expandable": true,
          "title": "${config.title.accessory}",
          "items": [
            "accessories[].info.name",
            "accessories[].info.type",
            {
              "type": "fieldset",
              "title": "${config.title.info}",
              "expandable": true,
              "items": [
                "accessories[].info.manufacturer",
                "accessories[].info.model",
                "accessories[].info.serialNumber",
                "accessories[].info.version"
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.mqtt}",
              "items": [
                "accessories[].mqtt.broker",
                "accessories[].mqtt.options"
              ]
            },
            "accessories[].disableLogging",
            {
              "type": "fieldset",
              "title": "${config.title.topics}",
              "description": "${config.description.topics}",
              "items": [
                {
                  "key": "accessories[].topicGetCurrent",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicGetTarget",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicSetTarget",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicGetOn",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'Switch';"
                  }
                },
                {
                  "key": "accessories[].topicSetOn",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'Switch';"
                  }
                },
                "accessories[].topicGetActive"
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.values}",
              "items": [
                {
                  "key": "accessories[].valueSecured",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].valueUnsecured",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].valueJammed",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].valueOn",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'Switch';"
                  }
                },
                {
                  "key": "accessories[].valueOff",
                  "condition": {
                    "functionBody": "const index = arguments[1]; return model.accessories[index]?.info.type === 'Switch';"
                  }
                },
                "accessories[].valueActive"
              ]
            }
          ]
        }
      ]
    },
    "verbose"
  ]
}