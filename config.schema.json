                  },
                  "items": [
                    {
                      "type": "div",
                      "displayFlex": true,
                      "flex-direction": "row",
                      "items": [
                        {
                          "key": "accessories[].topicGetCarbonMonoxideDetected",
                          "flex": "0 0 50%"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "displayFlex": true,
                      "flex-direction": "row",
                      "items": [
                        {
                          "key": "accessories[].topicGetCarbonMonoxideLevel",
                          "flex": "0 0 50%"
                        },
                        {
                          "key": "accessories[].topicGetCarbonMonoxidePeakLevel",
                          "flex": "0 0 50%"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
