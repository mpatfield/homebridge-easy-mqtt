{
  "pluginAlias": "HomebridgeEasyMQTT",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "schema": {
    "type": "object",
    "definitions": {
      "info": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "title": "${config.title.name}" ,         
            "required": true
          },
          "type": {
            "type": "string",
            "title": "${config.title.type}",
            "enum": [ "Lightbulb", "LockMechanism", "Outlet", "Switch", "TemperatureSensor"],
            "enumNames": ["${config.enumNames.lightbulb}", "${config.enumNames.lockMechanism}", "${config.enumNames.outlet}", "${config.enumNames.switch}",  "${config.enumNames.temperatureSensor}"],
            "required": true
          },
          "manufacturer": {
            "type": "string",
            "title": "${config.title.manufacturer}"
          },
          "model": {
            "type": "string",
            "title": "${config.title.model}"
          },
          "serialNumber": {
            "type": "string",
            "title": "${config.title.serialNumber}"
          },
          "version": {
            "type": "string",
            "title": "${config.title.version}"
          }
        }
      },
      "mqtt": {
        "type": "object",
        "properties": {
          "broker": {
            "type": "string",
            "title": "${config.title.broker}",
            "placeholder": "mqtts://192.168.0.1:1883",
            "required": true
          },
          "username": {
            "type": "string",
            "title": "${config.title.username}"
          },
          "password": {
            "type": "string",
            "title": "${config.title.password}"
          },
          "options": {
            "type": "string",
            "title": "${config.title.options}",
            "description": "${config.description.options}",
            "placeholder": "{ \"protocolVersion\": \"4\", \"clientId\": \"my-client-id\", \"rejectUnauthorized\": true }"
          }
        }
      }
    },    
    "properties": {
      "name": {
        "type": "string",
        "default": "Easy MQTT"
      },
      "accessories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "info": { "$ref": "#/definitions/info" },
            "mqtt": { "$ref": "#/definitions/mqtt" },
            "temperatureUnits": {
              "type": "string",
              "title": "${config.title.temperatureUnits}",
              "enum": ["C", "F"],
              "enumNames": ["${config.enumNames.celsius}", "${config.enumNames.fahrenheit}"]
            },
            "topicGetStatusActive": {
              "type": "string",
              "title": "${config.title.topicGetStatusActive}"
            },
            "topicGetBrightness": {
              "type": "string",
              "title": "${config.title.topicGetBrightness}"
            },
            "topicSetBrightness": {
              "type": "string",
              "title": "${config.title.topicSetBrightness}"
            },
            "topicGetHue": {
              "type": "string",
              "title": "${config.title.topicGetHue}"
            },
            "topicSetHue": {
              "type": "string",
              "title": "${config.title.topicSetHue}"
            },
            "topicGetColorTemperature": {
              "type": "string",
              "title": "${config.title.topicGetColorTemperature}"
            },
            "topicSetColorTemperature": {
              "type": "string",
              "title": "${config.title.topicSetColorTemperature}"
            },
            "topicGetSaturation": {
              "type": "string",
              "title": "${config.title.topicGetSaturation}"
            },
            "topicSetSaturation": {
              "type": "string",
              "title": "${config.title.topicSetSaturation}"
            },
            "topicGetLockCurrentState": {
              "type": "string",
              "title": "${config.title.topicGetLockCurrentState}"
            },
            "topicGetLockTargetState": {
              "type": "string",
              "title": "${config.title.topicGetLockTargetState}"
            },
            "topicSetTargetState": {
              "type": "string",
              "title": "${config.title.topicSetTargetState}"
            },
            "topicGetOn": {
              "type": "string",
              "title": "${config.title.topicGetOn}"
            },
            "topicSetOn": {
              "type": "string",
              "title": "${config.title.topicSetOn}"
            },
            "topicGetOutletInUse": {
              "type": "string",
              "title": "${config.title.topicGetOutletInUse}"
            },
            "topicSetOutletInUse": {
              "type": "string",
              "title": "${config.title.topicSetOutletInUse}"
            },
            "topicGetCurrentTemperature": {
              "type": "string",
              "title": "${config.title.topicGetCurrentTemperature}"
            },
            "valueStatusActive": {
              "type": "string",
              "title": "${config.title.valueStatusActive}",
              "description": "${config.description.valueStatusActive}"
            },
            "valueLockStateSecured": {
              "type": "string",
              "title": "${config.title.valueLockStateSecured}"
            },
            "valueLockStateUnsecured": {
              "type": "string",
              "title": "${config.title.valueLockStateUnsecured}"
            },
            "valueLockStateJammed": {
              "type": "string",
              "title": "${config.title.valueLockStateJammed}"
            },
            "valueOn": {
              "type": "string",
              "title": "${config.title.valueOn}"
            },
            "valueOff": {
              "type": "string",
              "title": "${config.title.valueOff}"
            },
            "valueOutletInUse": {
              "type": "string",
              "title": "${config.title.valueOutletInUse}"
            },
            "valueOutletNotInUse": {
              "type": "string",
              "title": "${config.title.valueOutletNotInUse}"
            },
            "disableLogging": {
              "type": "boolean",
              "title": "${config.title.disableLogging}",
              "description": "${config.description.disableLogging}"
            }
          }
        },
        "default": []
      }
    }
  },
  "layout": [
    {
      "type": "array",
      "key": "accessories",
      "notitle": true,
      "items": [
        {
          "type": "fieldset",
          "expandable": true,
          "title": "${config.title.accessory}",
          "items": [
            {
              "type": "div",
              "displayFlex": true,
              "flex-direction": "row",
              "items": [
                {
                  "key": "accessories[].info.name",
                  "flex": "1 1 33%"
                },
                {
                  "key": "accessories[].info.type",
                  "flex": "1 1 33%"
                },
                {
                  "key": "accessories[].temperatureUnits",
                  "flex": "1 1 33%",                  
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'TemperatureSensor';"
                  }
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.info}",
              "expandable": true,
              "items": [
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].info.manufacturer",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].info.model",
                      "flex": "1 1 0"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].info.serialNumber",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].info.version",
                      "flex": "1 1 0"
                    }
                  ]
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.mqtt}",
              "items": [
                "accessories[].mqtt.broker",
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].mqtt.username",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].mqtt.password",
                      "flex": "1 1 0"
                    }
                  ]
                },
                "accessories[].mqtt.options"
              ]
            },
            "accessories[].disableLogging",
            {
              "type": "fieldset",
              "title": "${config.title.topics}",
              "items": [
                {
                  "key": "accessories[].topicGetLockCurrentState",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicGetLockTargetState",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicSetTargetState",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicGetOn",
                  "condition": {
                    "functionBody": "return ['Lightbulb', 'Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  }
                },
                {
                  "key": "accessories[].topicSetOn",
                  "condition": {
                    "functionBody": "return ['Lightbulb', 'Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  }
                },
                {
                  "key": "accessories[].topicGetBrightness",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicSetBrightness",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicGetHue",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicSetHue",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicGetColorTemperature",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicSetColorTemperature",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicGetSaturation",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicSetSaturation",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "key": "accessories[].topicGetOutletInUse",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  }
                },
                {
                  "key": "accessories[].topicSetOutletInUse",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  }
                },
                {
                  "key": "accessories[].topicGetCurrentTemperature",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'TemperatureSensor';"
                  }
                },
                "accessories[].topicGetStatusActive"
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.values}",
              "items": [
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueLockStateSecured",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueLockStateUnsecured",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueLockStateJammed",
                      "flex": "1 1 0"
                    }                    
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return ['Lightbulb', 'Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueOn",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueOff",
                      "flex": "1 1 0"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueOutletInUse",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueOutletNotInUse",
                      "flex": "1 1 0"
                    }
                  ]
                },
                "accessories[].valueStatusActive"
              ]
            }          
          ]
        }
      ]
    }
  ]
}