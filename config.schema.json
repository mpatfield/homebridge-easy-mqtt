                      ]
                    },
                    {
                      "type": "div",
                      "displayFlex": true,
                      "flex-direction": "row",
                      "items": [
                        {
                          "key": "accessories[].topicGetCarbonDioxideLevel",
                          "flex": "0 0 50%"
                        },
                        {
