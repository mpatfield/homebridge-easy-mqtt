                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'MotionSensor';"
                  },
                  "items": [
                    {
                      "key": "accessories[].topicGetMotionDetected",
                      "flex": "0 0 50%"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'OccupancySensor';"
                  },
