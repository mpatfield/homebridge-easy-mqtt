{
  "pluginAlias": "HomebridgeEasyMQTT",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "schema": {
    "type": "object",
    "definitions": {
      "info": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "title": "${config.title.name}" ,
            "required": true
          },
          "type": {
            "type": "string",
            "title": "${config.title.type}",
            "enum": [ "CarbonMonoxideSensor", "CarbonDioxideSensor", "ContactSensor", "HumiditySensor", "LeakSensor", "Lightbulb", "LockMechanism", "MotionSensor", "OccupancySensor", "Outlet", "SecuritySystem", "SmokeSensor", "Switch", "TemperatureSensor", "Thermostat"],
            "enumNames": ["${config.enumNames.carbonMonoxideSensor}", "${config.enumNames.carbonDioxideSensor}", "${config.enumNames.contactSensor}", "${config.enumNames.humiditySensor}", "${config.enumNames.leakSensor}", "${config.enumNames.lightbulb}", "${config.enumNames.lockMechanism}", "${config.enumNames.motionSensor}", "${config.enumNames.occupancySensor}", "${config.enumNames.outlet}", "${config.enumNames.securitySystem}", "${config.enumNames.smokeSensor}", "${config.enumNames.switch}",  "${config.enumNames.temperatureSensor}", "${config.enumNames.thermostat}"],
            "required": true
          },
          "manufacturer": {
            "type": "string",
            "title": "${config.title.manufacturer}"
          },
          "model": {
            "type": "string",
            "title": "${config.title.model}"
          },
          "serialNumber": {
            "type": "string",
            "title": "${config.title.serialNumber}"
          },
          "version": {
            "type": "string",
            "title": "${config.title.version}"
          }
        }
      },
      "mqtt": {
        "type": "object",
        "properties": {
          "broker": {
            "type": "string",
            "title": "${config.title.broker}",
            "placeholder": "mqtts://192.168.0.1:1883",
            "required": true
          },
          "username": {
            "type": "string",
            "title": "${config.title.username}"
          },
          "password": {
            "type": "string",
            "title": "${config.title.password}"
          },
          "options": {
            "type": "string",
            "title": "${config.title.options}",
            "description": "${config.description.options}",
            "placeholder": "{ \"protocolVersion\": \"4\", \"clientId\": \"my-client-id\", \"rejectUnauthorized\": true }"
          }
        }
      },
      "customCharacteristic": {
        "type": "object",
        "properties": {
          "uuid": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "getTopic": {
            "type": "string"
          },
          "units": {
            "type": "string"
          }
        }
      }
    },
    "properties": {
      "name": {
        "type": "string",
        "default": "Easy MQTT"
      },
      "accessories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "info": { "$ref": "#/definitions/info" },
            "mqtt": { "$ref": "#/definitions/mqtt" },
            "customCharacteristics": {
              "type": "array",
              "items": { "$ref": "#/definitions/customCharacteristic" }
            },
            "temperatureUnits": {
              "type": "string",
              "enum": ["C", "F"],
              "enumNames": ["${config.enumNames.celsius}", "${config.enumNames.fahrenheit}"]
            },
            "topicGetBatteryLevel": {
