                        {
                          "key": "accessories[].topicGetStatusTampered",
                          "flex": "0 0 50%"
                        },
                        {
                          "key": "accessories[].topicGetStatusFault",
                          "flex": "0 0 50%"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "fieldset",
                  "notitle": true,
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'CarbonDioxideSensor';"
                  },
                  "items": [
                    {
                      "type": "div",
                      "displayFlex": true,
                      "flex-direction": "row",
                      "items": [
                        {
                          "key": "accessories[].topicGetCarbonDioxideDetected",
                          "flex": "0 0 50%"
