{
  "pluginAlias": "HomebridgeEasyMQTT",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "schema": {
    "type": "object",
    "definitions": {
      "info": {
        "type": "object",
        "properties": {
          "name": {
              "type": "string",
              "title": "${config.title.name}" ,         
              "required": true
            },
          "type": {
            "type": "string",
            "title": "${config.title.type}",
            "enum": [
              "LockMechanism",
              "Outlet",
              "Switch"
            ],
            "required": true
          },
          "manufacturer": {
            "type": "string",
            "title": "${config.title.manufacturer}"
          },
          "model": {
            "type": "string",
            "title": "${config.title.model}"
          },
          "serialNumber": {
            "type": "string",
            "title": "${config.title.serialNumber}"
          },
          "version": {
            "type": "string",
            "title": "${config.title.version}"
          }
        }
      },
      "mqtt": {
        "type": "object",
        "properties": {
          "broker": {
            "type": "string",
            "title": "${config.title.broker}",
            "placeholder": "mqtts://192.168.0.1:1883",
            "required": true
          },
          "username": {
            "type": "string",
            "title": "${config.title.username}"
          },
          "password": {
            "type": "string",
            "title": "${config.title.password}"
          },
          "options": {
            "type": "string",
            "title": "${config.title.options}",
            "description": "${config.description.options}",
            "placeholder": "{ \"protocolVersion\": \"4\", \"clientId\": \"my-client-id\", \"rejectUnauthorized\": true }"
          }
        }
      }
    },    
    "properties": {
      "name": {
        "type": "string",
        "default": "Easy MQTT"
      },
      "accessories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "info": { "$ref": "#/definitions/info" },
            "mqtt": { "$ref": "#/definitions/mqtt" },
            "topicGetActive": {
              "type": "string",
              "title": "${config.title.topicGetActive}",
              "placeholder": "zwave/door_lock/status"
            },
            "topicGetCurrent": {
              "type": "string",
              "title": "${config.title.topicGetCurrent}",
              "placeholder": "zwave/door_lock/currentMode"
            },
            "topicGetTarget": {
              "type": "string",
              "title": "${config.title.topicGetTarget}",
              "placeholder": "zwave/door_lock/targetMode"
            },
            "topicSetTarget": {
              "type": "string",
              "title": "${config.title.topicSetTarget}",
              "placeholder": "zwave/door_lock/targetMode/set"
            },
            "topicGetOn": {
              "type": "string",
              "title": "${config.title.topicGetOn}",
              "placeholder": "home/kitchen_lights/state"
            },
            "topicSetOn": {
              "type": "string",
              "title": "${config.title.topicSetOn}",
              "placeholder": "home/kitchen_lights/state/set"
            },
            "topicGetInUse": {
              "type": "string",
              "title": "${config.title.topicGetInUse}",
              "placeholder": "home/bedroom_outlet/state"
            },
            "topicSetInUse": {
              "type": "string",
              "title": "${config.title.topicSetInUse}",
              "placeholder": "home/bedroom_outlet/state/set"
            },
            "valueActive": {
              "type": "string",
              "title": "${config.title.valueActive}",
              "description": "${config.description.valueActive}"
            },
            "valueSecured": {
              "type": "string",
              "title": "${config.title.valueSecured}"
            },
            "valueUnsecured": {
              "type": "string",
              "title": "${config.title.valueUnsecured}"
            },
            "valueJammed": {
              "type": "string",
              "title": "${config.title.valueJammed}"
            },
            "valueOn": {
              "type": "string",
              "title": "${config.title.valueOn}"
            },
            "valueOff": {
              "type": "string",
              "title": "${config.title.valueOff}"
            },
            "valueInUse": {
              "type": "string",
              "title": "${config.title.valueInUse}"
            },
            "valueNotInUse": {
              "type": "string",
              "title": "${config.title.valueNotInUse}"
            },
            "disableLogging": {
              "type": "boolean",
              "title": "${config.title.disableLogging}",
              "description": "${config.description.disableLogging}"
            }
          }
        },
        "default": []
      },
      "verbose": {
        "type": "boolean",
        "title": "${config.title.verbose}",
        "description": "${config.description.verbose}"
      }
    }
  },
  "layout": [
    {
      "type": "array",
      "key": "accessories",
      "title": "${config.title.accessories}",
      "items": [
        {
          "type": "fieldset",
          "expandable": true,
          "title": "${config.title.accessory}",
          "items": [
            {
              "type": "div",
              "displayFlex": true,
              "flex-direction": "row",
              "items": [
                {
                  "key": "accessories[].info.name",
                  "flex": "1 1 0"
                },
                {
                  "key": "accessories[].info.type",
                  "flex": "1 1 0"
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.info}",
              "expandable": true,
              "items": [
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].info.manufacturer",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].info.model",
                      "flex": "1 1 0"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].info.serialNumber",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].info.version",
                      "flex": "1 1 0"
                    }
                  ]
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.mqtt}",
              "items": [
                "accessories[].mqtt.broker",
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].mqtt.username",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].mqtt.password",
                      "flex": "1 1 0"
                    }
                  ]
                },
                "accessories[].mqtt.options"
              ]
            },
            "accessories[].disableLogging",
            {
              "type": "fieldset",
              "title": "${config.title.topics}",
              "items": [
                {
                  "key": "accessories[].topicGetCurrent",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicGetTarget",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicSetTarget",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "key": "accessories[].topicGetOn",
                  "condition": {
                    "functionBody": "return ['Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  }
                },
                {
                  "key": "accessories[].topicSetOn",
                  "condition": {
                    "functionBody": "return ['Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  }
                },
                                {
                  "key": "accessories[].topicGetInUse",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  }
                },
                {
                  "key": "accessories[].topicSetInUse",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  }
                },
                "accessories[].topicGetActive"
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.values}",
              "items": [
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueSecured",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueUnsecured",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueJammed",
                      "flex": "1 1 0"
                    }                    
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return ['Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueOn",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueOff",
                      "flex": "1 1 0"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueInUse",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].valueNotInUse",
                      "flex": "1 1 0"
                    }
                  ]
                },
                "accessories[].valueActive"
              ]
            }          
          ]
        }
      ]
    },
    "verbose"
  ]
}