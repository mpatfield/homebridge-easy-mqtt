{
  "pluginAlias": "HomebridgeEasyMQTT",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./dist/homebridge-ui",
  "schema": {
    "type": "object",
    "definitions": {
      "info": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string",
            "title": "${config.title.name}" ,
            "required": true
          },
          "type": {
            "type": "string",
            "title": "${config.title.type}",
            "enum": [ "Lightbulb", "LockMechanism", "Outlet", "SecuritySystem", "Switch", "TemperatureSensor"],
            "enumNames": ["${config.enumNames.lightbulb}", "${config.enumNames.lockMechanism}", "${config.enumNames.outlet}", "${config.enumNames.securitySystem}", "${config.enumNames.switch}",  "${config.enumNames.temperatureSensor}"],
            "required": true
          }
        }
      },
      "mqtt": {
        "type": "object",
        "properties": {
          "broker": {
            "type": "string",
            "title": "${config.title.broker}",
            "placeholder": "mqtts://192.168.0.1:1883",
            "required": true
          },
          "username": {
            "type": "string",
            "title": "${config.title.username}"
          },
          "password": {
            "type": "string",
            "title": "${config.title.password}"
          },
          "options": {
            "type": "string",
            "title": "${config.title.options}",
            "description": "${config.description.options}",
            "placeholder": "{ \"protocolVersion\": \"4\", \"clientId\": \"my-client-id\", \"rejectUnauthorized\": true }"
          }
        }
      }
    },
    "properties": {
      "name": {
        "type": "string",
        "default": "Easy MQTT"
      },
      "accessories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "info": { "$ref": "#/definitions/info" },
            "mqtt": { "$ref": "#/definitions/mqtt" },
            "temperatureUnits": {
              "type": "string",
              "enum": ["C", "F"],
              "enumNames": ["${config.enumNames.celsius}", "${config.enumNames.fahrenheit}"]
            },
            "topicGetStatusActive": {
              "type": "string",
              "title": "${config.title.topicGetStatusActive}"
            },
            "topicGetBrightness": {
              "type": "string",
              "title": "${config.title.topicGetBrightness}"
            },
            "topicSetBrightness": {
              "type": "string",
              "title": "${config.title.topicSetBrightness}"
            },
            "topicGetHue": {
              "type": "string",
              "title": "${config.title.topicGetHue}"
            },
            "topicSetHue": {
              "type": "string",
              "title": "${config.title.topicSetHue}"
            },
            "topicGetColorTemperature": {
              "type": "string",
              "title": "${config.title.topicGetColorTemperature}"
            },
            "topicSetColorTemperature": {
              "type": "string",
              "title": "${config.title.topicSetColorTemperature}"
            },
            "topicGetSaturation": {
              "type": "string",
              "title": "${config.title.topicGetSaturation}"
            },
            "topicSetSaturation": {
              "type": "string",
              "title": "${config.title.topicSetSaturation}"
            },
            "topicGetCurrentLockState": {
              "type": "string",
              "title": "${config.title.topicGetCurrentLockState}"
            },
            "topicGetTargetLockState": {
              "type": "string",
              "title": "${config.title.topicGetTargetLockState}"
            },
            "topicSetTargetLockState": {
              "type": "string",
              "title": "${config.title.topicSetTargetLockState}"
            },
            "topicGetOn": {
              "type": "string",
              "title": "${config.title.topicGetOn}"
            },
            "topicSetOn": {
              "type": "string",
              "title": "${config.title.topicSetOn}"
            },
            "topicGetOutletInUse": {
              "type": "string",
              "title": "${config.title.topicGetOutletInUse}"
            },
            "topicGetCurrentTemperature": {
              "type": "string",
              "title": "${config.title.topicGetCurrentTemperature}"
            },
            "topicGetCurrentSecurityState": {
              "type": "string",
              "title": "${config.title.topicGetCurrentSecurityState}"
            },
            "topicGetTargetSecurityState": {
              "type": "string",
              "title": "${config.title.topicGetTargetSecurityState}"
            },
            "topicSetTargetSecurityState": {
              "type": "string",
              "title": "${config.title.topicSetTargetSecurityState}"
            },
            "topicGetStatusTampered": {
              "type": "string",
              "title": "${config.title.topicGetStatusTampered}"
            },
            "topicGetStatusFault": {
              "type": "string",
              "title": "${config.title.topicGetStatusFault}"
            },
            "valueStatusActive": {
              "type": "string",
              "title": "${config.title.valueStatusActive}"
            },
            "valueLockStateSecured": {
              "type": "string",
              "title": "${config.title.valueLockStateSecured}"
            },
            "valueLockStateUnsecured": {
              "type": "string",
              "title": "${config.title.valueLockStateUnsecured}"
            },
            "valueLockStateJammed": {
              "type": "string",
              "title": "${config.title.valueLockStateJammed}"
            },
            "valueOn": {
              "type": "string",
              "title": "${config.title.valueOn}"
            },
            "valueOff": {
              "type": "string",
              "title": "${config.title.valueOff}"
            },
            "valueOutletInUse": {
              "type": "string",
              "title": "${config.title.valueOutletInUse}"
            },
            "valueArmStay": {
              "type": "string",
              "title": "${config.title.valueArmStay}"
            },
            "valueArmAway": {
              "type": "string",
              "title": "${config.title.valueArmAway}"
            },
            "valueArmNight": {
              "type": "string",
              "title": "${config.title.valueArmNight}"
            },
            "valueDisarm": {
              "type": "string",
              "title": "${config.title.valueDisarm}"
            },
            "valueAlarmTriggered": {
              "type": "string",
              "title": "${config.title.valueAlarmTriggered}"
            },
            "valueTampered": {
              "type": "string",
              "title": "${config.title.valueTampered}"
            },
            "valueFault": {
              "type": "string",
              "title": "${config.title.valueFault}"
            },
            "disableLogging": {
              "type": "boolean",
              "title": "${config.title.disableLogging}",
              "description": "${config.description.disableLogging}"
            }
          }
        },
        "default": []
      }
    }
  },
  "layout": [
    {
      "type": "array",
      "key": "accessories",
      "notitle": true,
      "items": [
        {
          "type": "fieldset",
          "expandable": true,
          "title": "${config.title.accessory}",
          "items": [
            {
              "type": "div",
              "displayFlex": true,
              "flex-direction": "row",
              "items": [
                {
                  "key": "accessories[].info.name",
                  "flex": "1 1 0"
                },
                {
                  "key": "accessories[].info.type",
                  "flex": "1 1 0"
                }
              ]
            },
            {
              "type": "fieldset",
              "items": [
                "accessories[].mqtt.broker",
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].mqtt.username",
                      "flex": "1 1 0"
                    },
                    {
                      "key": "accessories[].mqtt.password",
                      "flex": "1 1 0"
                    }
                  ]
                },
                "accessories[].mqtt.options"
              ]
            },
            "accessories[].disableLogging",
            {
              "type": "fieldset",
              "title": "${config.title.topics}",
              "condition": {
                "functionBody": "return model.accessories?.[arguments[1]]?.info?.type !== undefined;"
              },
              "items": [
                {
                  "type": "fieldset",
                  "notitle": "true",
                  "items": [
                    "accessories[].topicGetCurrentLockState",
                    "accessories[].topicGetTargetLockState",
                    "accessories[].topicSetTargetLockState"
                  ],
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  }
                },
                {
                  "type": "fieldset",
                  "notitle": "true",
                  "items": [
                    "accessories[].topicGetOn",
                    "accessories[].topicSetOn"
                  ],
                  "condition": {
                    "functionBody": "return ['Lightbulb', 'Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  }
                },
                {
                  "type": "fieldset",
                  "notitle": "true",
                  "items": [
                    "accessories[].topicGetBrightness",
                    "accessories[].topicSetBrightness",
                    "accessories[].topicGetHue",
                    "accessories[].topicSetHue",
                    "accessories[].topicGetColorTemperature",
                    "accessories[].topicSetColorTemperature",
                    "accessories[].topicGetSaturation",
                    "accessories[].topicSetSaturation"
                  ],
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Lightbulb';"
                  }
                },
                {
                  "type": "fieldset",
                  "notitle": "true",
                  "items": [
                    "accessories[].topicGetOutletInUse"
                  ],
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  }
                },
                {
                  "type": "fieldset",
                  "notitle": "true",
                  "items": [
                    "accessories[].topicGetCurrentSecurityState",
                    "accessories[].topicGetTargetSecurityState",
                    "accessories[].topicSetTargetSecurityState",
                    "accessories[].topicGetStatusTampered",
                    "accessories[].topicGetStatusFault"
                  ],
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'SecuritySystem';"
                  }
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'TemperatureSensor';"
                  },
                  "items": [
                    {
                      "key": "accessories[].topicGetCurrentTemperature",
                      "flex": "1 1 67%"
                    },
                    {
                      "key": "accessories[].temperatureUnits",
                      "title": "${config.title.sourceUnits}",
                      "flex": "1 1 33%"
                    }
                  ]
                },
                "accessories[].topicGetStatusActive"
              ]
            },
            {
              "type": "fieldset",
              "title": "${config.title.values}",
              "condition": {
                "functionBody": "return model.accessories?.[arguments[1]]?.info?.type !== undefined;"
              },
              "items": [
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'LockMechanism';"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueLockStateSecured",
                      "flex": "0 0 25%"
                    },
                    {
                      "key": "accessories[].valueLockStateUnsecured",
                      "flex": "0 0 25%"
                    },
                    {
                      "key": "accessories[].valueLockStateJammed",
                      "flex": "0 0 25%"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return ['Lightbulb', 'Outlet', 'Switch'].includes(model.accessories?.[arguments[1]]?.info?.type);"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueOn",
                      "flex": "0 0 25%"
                    },
                    {
                      "key": "accessories[].valueOff",
                      "flex": "0 0 25%"
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'Outlet';"
                  },
                  "items": [
                    {
                      "key": "accessories[].valueOutletInUse",
                      "flex": "0 0 25%"
                    }
                  ]
                },
                {
                  "type": "fieldset",
                  "notitle": true,
                  "condition": {
                    "functionBody": "return model.accessories?.[arguments[1]]?.info?.type === 'SecuritySystem';"
                  },
                  "items": [
                    {
                      "type": "div",
                      "displayFlex": true,
                      "flex-direction": "row",
                      "items": [
                        {
                          "key": "accessories[].valueArmStay",
                          "flex": "0 0 25%"
                        },
                        {
                          "key": "accessories[].valueArmAway",
                          "flex": "0 0 25%"
                        },
                        {
                          "key": "accessories[].valueArmNight",
                          "flex": "0 0 25%"
                        },
                        {
                          "key": "accessories[].valueDisarm",
                          "flex": "0 0 25%"
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "displayFlex": true,
                      "flex-direction": "row",
                      "items": [
                        {
                          "key": "accessories[].valueAlarmTriggered",
                          "flex": "0 0 25%"
                        },
                        {
                          "key": "accessories[].valueTampered",
                          "flex": "0 0 25%"
                        },
                        {
                          "key": "accessories[].valueFault",
                          "flex": "0 0 25%"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "div",
                  "displayFlex": true,
                  "flex-direction": "row",
                  "items": [
                    {
                      "key": "accessories[].valueStatusActive",
                      "flex": "0 0 25%"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}