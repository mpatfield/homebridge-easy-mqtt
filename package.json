{
  "name": "homebridge-easy-mqtt",
  "platform": "HomebridgeEasyMQTT",
  "displayName": "Homebridge Easy MQTT",
  "description": "Homebridge plugin for MQTT devices",
  "type": "module",
  "version": "1.5.12-beta.1",
  "homepage": "https://github.com/mpatfield/homebridge-easy-mqtt#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mpatfield/homebridge-easy-mqtt.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/mpatfield"
  },
  "bugs": {
    "url": "https://github.com/mpatfield/homebridge-easy-mqtt/issues"
  },
  "main": "dist/homebridge/index.js",
  "scripts": {
    "build": "rimraf ./dist ./schemas ./config.schema.json && tsc && npm run build:html && npm run build:schemas",
    "build:html": "node --import tsx ./scripts/build-html.ts",
    "build:schemas": "node --import tsx ./scripts/build-schemas.ts",
    "i18n": "npm run i18n:merge && npm run i18n:clean && npm run i18n:missing",
    "i18n:clean": "node --import tsx ./scripts/i18n-clean.ts",
    "i18n:merge": "node --import tsx ./scripts/i18n-merge.ts",
    "i18n:missing": "node --import tsx ./scripts/i18n-missing.ts",
    "lint": "eslint . --fix --max-warnings=0",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge",
    "homebridge-plugin",
    "homebridge-easy-mqtt",
    "hoobs",
    "hoobs-plugin",
    "homekit",
    "mqtt",
    "shelly",
    "sonoff",
    "tasmota",
    "tuya",
    "zigbee",
    "zigbee2mqtt"
  ],
  "engines": {
    "homebridge": "^1.8.0 || ^2.0.0-beta.0",
    "node": "^20 || ^22 || ^24"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.2",
    "fakegato-history": "file:./lib/fakegato-history",
    "homebridge-lib": "^7.1.6",
    "lodash.merge": "^4.6.2",
    "mqtt": "^5.7.0",
    "node-persist": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash.merge": "^4.6.9",
    "@types/node-persist": "^3.1.8",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.2",
    "homebridge": "^2.0.0-beta.29",
    "jiti": "^2.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4"
  },
  "homebridge": {
    "platform": "HomebridgeEasyMQTT",
    "name": "homebridge-easy-mqtt"
  },
  "directories": {
    "schemas": "schemas/"
  },
  "author": {
    "name": "mpatfield"
  },
  "license": "Apache-2.0"
}
